rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Rate limit counters — written only by the backend (Admin SDK bypasses rules)
    match /rateLimits/{doc} {
      allow read, write: if false;
    }

    // ── Invalidated refresh tokens — written only by backend
    match /invalidatedRefreshTokens/{doc} {
      allow read, write: if false;
    }

    // ── Users — only the owning user can read/write their own document and subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── ChatSessions — user can read/write their own chat sessions and messages
    match /chatSessions/{sessionId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Orders — owning user can read their own orders; no client writes
    match /orders/{orderId} {
      allow read:  if request.auth != null
                   && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
