# .env.example
# All sensitive secrets (Gemini API, Payment Gateways, Email services, JWT keys) MUST be kept on the backend only.
# Do NOT embed these in your frontend build bundle.

# AI & LLM Service (Backend Only)
GEMINI_API_KEY="your_gemini_api_key_here"

# Authentication Secrets (Backend Only)
JWT_SECRET="super-secret-access-key-career-suggestor"
JWT_REFRESH_SECRET="super-secret-refresh-key-career-suggestor"

# External Payment Gateway (Backend Only)
STRIPE_SECRET_KEY="sk_test_yourStripeSecretKeyHere"

# Email / Notification Service (Backend Only)
SENDGRID_API_KEY="SG.yourSendGridApiKeyHere"

# Application Config
APP_URL="http://localhost:3000"
REDIS_URL="redis://localhost:6379"
